# --- Airwallex 空中云汇 (server: create Payment Intent; never commit real keys) ---
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# demo | prod
AIRWALLEX_ENV=demo
# Amount in smallest currency unit (e.g. USD cents). Default 100 = US$1.00
AIRWALLEX_DEFAULT_AMOUNT_MINOR=100
AIRWALLEX_DEFAULT_CURRENCY=USD

# Browser SDK (safe to expose — Web App Client ID from Airwallex console)
NEXT_PUBLIC_AIRWALLEX_CLIENT_ID=
NEXT_PUBLIC_AIRWALLEX_ENV=demo

# If you use `output: 'export'` static hosting, Next.js does not deploy /api routes.
# Deploy the same logic as src/app/api/airwallex/intent on your server (Vercel, Cloudflare Worker, etc.),
# enable CORS for POST from your shop origin, then set:
# NEXT_PUBLIC_AIRWALLEX_INTENT_API=https://your-api.example.com/airwallex/intent

# --- Airwallex Webhooks（支付成功即时通知）---
# 在 Airwallex 后台创建 Webhook，通知 URL 填: https://你的域名/api/airwallex/webhook/
# 勾选事件 payment_intent.succeeded，保存后复制该订阅的 Secret 填到下面：
AIRWALLEX_WEBHOOK_SECRET=

# 至少配置一种通知方式（可同时配置）：
# 任意 HTTPS 地址，POST JSON（已适配 Discord / Slack / 企业微信机器人 URL）
ORDER_NOTIFY_WEBHOOK_URL=
# Telegram：@BotFather 创建机器人后取 token；与机器人对话后查 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 支付成功 → QQ / 企业邮箱（SMTP，与 Telegram 可同时使用）---
# 收件人（可填你的 QQ 邮箱）
ORDER_NOTIFY_EMAIL_TO=
# QQ 邮箱一般为 smtp.qq.com / 465；SMTP_PASS 为邮箱「授权码」非登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
# 留空或 true=SSL；若用 587 填 SMTP_PORT=587 且 SMTP_SECURE=false
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# 可选，默认等于 SMTP_USER
SMTP_FROM=

# --- 可选：Twilio 国际短信（发到 +86 需 Twilio 支持；国内多用阿里云/腾讯云短信模板）---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
ORDER_NOTIFY_SMS_TO=

# --- 邮件营销 / 页脚订阅（三选一，优先级从上到下）---
# Omnisend: Store settings → API keys → 创建 Key；联系人会打标签 thangka-shop / footer-newsletter
OMNISEND_API_KEY=
# 可选，逗号分隔，例如: vip,website
OMNISEND_TAGS=
# Mailchimp: API Key 形如 xxxxx-us19；Audience ID
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
# 任意 HTTPS，POST JSON { email, source, subscribed_at }
NEWSLETTER_WEBHOOK_URL=

# --- Stripe Checkout（与 https://docs.stripe.com/billing/quickstart 一致：Dashboard 创建 Product + Price）---
STRIPE_SECRET_KEY=
# Webhook 签名密钥；端点 URL: https://你的域名/api/stripe/webhook/
STRIPE_WEBHOOK_SECRET=
# 二选一：Price 的 lookup_key（推荐，与官方示例一致）或直接使用 price_xxx
STRIPE_PRICE_LOOKUP_KEY=
STRIPE_PRICE_ID=
# subscription（默认，订阅）| payment（一次性支付，需 Price 为一次性定价）
STRIPE_CHECKOUT_MODE=subscription
# 生产环境请设为 https://你的域名（用于 success/cancel 跳转；本地可留空，将使用当前请求的 origin）
NEXT_PUBLIC_SITE_URL=
# 若使用 output:export 静态托管，自行部署创建 Session 的 API 后填完整 URL
NEXT_PUBLIC_STRIPE_CHECKOUT_API=

# --- 站点联系信息（页脚、支付页；可选覆盖 en/zh 文案里的默认电话/邮箱）---
NEXT_PUBLIC_SITE_PHONE=
NEXT_PUBLIC_SITE_EMAIL=
NEXT_PUBLIC_SITE_EMAIL_2=

# --- 账户：若使用 Shopify / Clerk 等外链登录，填完整 URL（否则使用站内浏览器本地演示账户）---
NEXT_PUBLIC_AUTH_LOGIN_URL=
NEXT_PUBLIC_AUTH_SIGNUP_URL=

# --- 分析 & 聊天（可选，均为可暴露的 NEXT_PUBLIC_）---
# Google Analytics 4 衡量 ID，如 G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# 第三方聊天/AI 客服：单一脚本地址。Tidio 示例: https://code.tidio.co/xxxx.js
NEXT_PUBLIC_CHAT_SCRIPT_URL=
